{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gift-album",
  "main": "backend/src/index.js",
  "compatibility_date": "2026-05-29",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "kv_namespaces": [
    { "binding": "AUTH_KV", "id": "7f64008189ec49a7938d402700845082" },
    { "binding": "GIFT_KV", "id": "42ad0c4238f641d5afee3e3dca5e8d4c" }
  ]
}
